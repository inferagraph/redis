{
  "name": "@inferagraph/redis",
  "version": "0.3.3",
  "description": "Redis-backed cache, conversation, embedding, and inferred-edge stores for @inferagraph/core.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inferagraph/redis.git"
  },
  "homepage": "https://github.com/inferagraph/redis#readme",
  "keywords": [
    "inferagraph",
    "cache",
    "redis",
    "rag",
    "vector",
    "embeddings",
    "llm",
    "ai"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "peerDependencies": {
    "@inferagraph/core": "^0.13.0"
  },
  "dependencies": {
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@inferagraph/core": "^0.13.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.1.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
